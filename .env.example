# Remote Ollama — set this to the remote host URL in CI/integration
OLLAMA_HOST=http://localhost:11434

# Model assignments — 4-model stack (no llama3.2)
MODEL_EMBED=nomic-embed-text:latest
MODEL_REASON=qwen3:14b
MODEL_SUMMARY=gemma4:e4b
# MODEL_FAST == MODEL_REASON disables the timeout-fallback path (we don't use llama3.2)
MODEL_FAST=qwen3:14b
MODEL_VISION=llava:7b

# Ingest / retrieval tuning
CONFIDENCE_THRESHOLD=0.60
PDF_CHUNK_PAGES=3
INGEST_OVERLAP=200
# 1 = strictly sequential; avoids Ollama model-swap thrashing
MAX_CONCURRENT_LLM_REQ=1

# Paths (relative to repo root)
WIKI_DIR=wiki
RAW_DIR=wiki/raw
DATA_DIR=data
LOGS_DIR=logs

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Timeouts (seconds) — generous because cold-load of gemma4/qwen3 can take 30-60s
LLM_TIMEOUT=600
LLM_FAST_TIMEOUT=120
